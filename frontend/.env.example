# Copy this file to `.env` in this directory (`frontend/.env`) and adjust values.
# Expo loads `.env` when you run `npx expo start` from `frontend/` or via the workspace script from the repo root.
# Restart Metro after any change (quit then `npm run start:frontend` again).

# Base URL of the FastAPI backend (no trailing slash).
# Choose the host that matches how you run the app:
#
# - iOS Simulator or Expo web on the same machine as the API:
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
#
# - Android emulator (PREFERRED - use your Mac's LAN IP, more reliable than 10.0.2.2):
#   Run `ifconfig en0 | grep "inet " | awk '{print $2}'` to find your current LAN IP
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.50:8000
#
# - Android emulator (ALTERNATIVE - host loopback, may not work on all macOS configurations):
# EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8000
#
# - Physical phone/tablet with a DEVELOPMENT BUILD (`npm run dev:ios:frontend` etc.):
#   You MAY use your computer's LAN IP over HTTP; app.config applies cleartext/ATS for local networking.
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.50:8000
#
# - Physical phone/tablet on EXPO GO with a LOCAL API:
#   Plain http:// to your Mac is often blocked inside Expo Go. Prefer an HTTPS URL (ngrok, Cloudflare Tunnel,
#   or a hosted API), or switch to a development build so native settings in app.config.js apply.
# EXPO_PUBLIC_API_BASE_URL=https://your-tunnel-subdomain.ngrok-free.app
#
# If this is unset, the app runs in local-only mode (no script upload / no server sync).
